{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run C++ Project (PowerShell 7)",
            "type": "shell",
            "command": "pwsh.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                ".\\run.ps1"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build the project and run it in a new PowerShell 7 window using run.ps1"
        }
    ]
}